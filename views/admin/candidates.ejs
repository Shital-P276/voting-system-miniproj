<%- include('../partials/header', { title: 'Candidates' }) %>

<div class="page-title">
    <h1>👤 Candidates — <%= election.title %></h1>
    <a href="/admin/elections" class="btn btn-sm" style="background:#eee;color:#333;">← Back</a>
</div>

<% if (election.status !== 'upcoming') { %>
    <div class="alert alert-error">⚠️ This election is <%= election.status %>. Candidates cannot be modified.</div>
<% } %>

<!-- Add candidate form -->
<% if (election.status === 'upcoming') { %>
<div class="card" style="max-width:600px;">
    <h2>Add Candidate</h2>
    <form action="/admin/elections/<%= election.id %>/candidates/add" method="POST">
        <div class="form-group">
            <label>Name *</label>
            <input type="text" name="name" required placeholder="Candidate full name">
        </div>
        <div class="form-group">
            <label>Party / Affiliation</label>
            <input type="text" name="party" placeholder="e.g. Progressive Party">
        </div>
        <div class="form-group">
            <label>Bio / Description</label>
            <textarea name="bio" placeholder="Brief candidate bio..."></textarea>
        </div>
        <button type="submit" class="btn btn-success">Add Candidate</button>
    </form>
</div>
<% } %>

<!-- Candidates list -->
<div class="card">
    <h2>Registered Candidates (<%= candidates.length %>)</h2>
    <% if (candidates.length === 0) { %>
        <p style="color:#888;">No candidates added yet.</p>
    <% } else { %>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Party</th>
                    <th>Bio</th>
                    <% if (election.status === 'upcoming') { %><th>Action</th><% } %>
                </tr>
            </thead>
            <tbody>
                <% candidates.forEach((c, i) => { %>
                <tr>
                    <td><%= i + 1 %></td>
                    <td><strong><%= c.name %></strong></td>
                    <td><%= c.party || '—' %></td>
                    <td><%= c.bio ? c.bio.substring(0, 80) + '...' : '—' %></td>
                    <% if (election.status === 'upcoming') { %>
                    <td>
                        <form action="/admin/candidates/<%= c.id %>/delete" method="POST" style="display:inline;">
                            <button class="btn btn-sm btn-danger" onclick="return confirm('Remove this candidate?')">Remove</button>
                        </form>
                    </td>
                    <% } %>
                </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
</div>

<%- include('../partials/footer') %>
