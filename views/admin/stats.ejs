<%- include('../partials/header', { title: 'Statistics' }) %>

<!-- Load Chart.js from CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="page-title">
    <h1>📊 Statistics — <%= election.title %></h1>
    <div class="btn-group">
        <a href="/admin/elections/<%= election.id %>/results" class="btn btn-sm btn-warning">Results</a>
        <a href="/admin/elections" class="btn btn-sm" style="background:#eee;color:#333;">← Back</a>
    </div>
</div>

<!-- Summary stats -->
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-num"><%= total_votes %></div>
        <div class="stat-label">Total Votes</div>
    </div>
    <div class="stat-card">
        <div class="stat-num"><%= results.length %></div>
        <div class="stat-label">Candidates</div>
    </div>
    <div class="stat-card">
        <div class="stat-num"><%= results[0] ? results[0].name.split(' ')[0] : '—' %></div>
        <div class="stat-label">Leading Candidate</div>
    </div>
    <div class="stat-card">
        <div class="stat-num"><span class="badge badge-<%= election.status %>"><%= election.status.toUpperCase() %></span></div>
        <div class="stat-label">Status</div>
    </div>
</div>

<div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">

    <!-- Bar Chart -->
    <div class="card">
        <h2>Vote Distribution (Bar)</h2>
        <canvas id="barChart" height="250"></canvas>
    </div>

    <!-- Pie Chart -->
    <div class="card">
        <h2>Vote Share (Pie)</h2>
        <canvas id="pieChart" height="250"></canvas>
    </div>

</div>

<!-- Timeline chart (if data exists) -->
<% if (timeline.length > 0) { %>
<div class="card">
    <h2>📈 Votes Over Time</h2>
    <canvas id="timelineChart" height="120"></canvas>
</div>
<% } %>

<!-- Data table -->
<div class="card">
    <h2>Full Breakdown</h2>
    <table>
        <thead>
            <tr><th>Rank</th><th>Candidate</th><th>Party</th><th>Votes</th><th>Share</th></tr>
        </thead>
        <tbody>
            <% results.forEach((r, i) => { %>
            <% const pct = total_votes > 0 ? ((r.vote_count / total_votes) * 100).toFixed(1) : '0.0'; %>
            <tr>
                <td><%= i === 0 && total_votes > 0 ? '🏆 1' : i + 1 %></td>
                <td><strong><%= r.name %></strong></td>
                <td><%= r.party || '—' %></td>
                <td><%= r.vote_count %></td>
                <td>
                    <div class="result-bar-bg" style="width:120px; display:inline-block; vertical-align:middle;">
                        <div class="result-bar-fill" style="width:<%= pct %>%;"></div>
                    </div>
                    <span style="margin-left:8px;"><%= pct %>%</span>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<script>
const labels  = <%- JSON.stringify(results.map(r => r.name)) %>;
const votes   = <%- JSON.stringify(results.map(r => Number(r.vote_count))) %>;
const parties = <%- JSON.stringify(results.map(r => r.party || 'Independent')) %>;

const COLORS = [
    '#1a237e','#1565c0','#0277bd','#00838f',
    '#2e7d32','#558b2f','#f57f17','#e65100'
];

// Bar chart
new Chart(document.getElementById('barChart'), {
    type: 'bar',
    data: {
        labels,
        datasets: [{
            label: 'Votes',
            data: votes,
            backgroundColor: COLORS.slice(0, labels.length),
            borderRadius: 6,
        }]
    },
    options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
    }
});

// Pie chart
new Chart(document.getElementById('pieChart'), {
    type: 'doughnut',
    data: {
        labels,
        datasets: [{
            data: votes,
            backgroundColor: COLORS.slice(0, labels.length),
            borderWidth: 2,
        }]
    },
    options: {
        responsive: true,
        plugins: {
            legend: { position: 'bottom' },
            tooltip: {
                callbacks: {
                    label: ctx => {
                        const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                        const pct = total > 0 ? ((ctx.parsed / total) * 100).toFixed(1) : 0;
                        return ` ${ctx.label}: ${ctx.parsed} votes (${pct}%)`;
                    }
                }
            }
        }
    }
});

// Timeline chart
<% if (timeline.length > 0) { %>
const timeLabels = <%- JSON.stringify(timeline.map(t => t.hour)) %>;
const timeCounts = <%- JSON.stringify(timeline.map(t => Number(t.count))) %>;

new Chart(document.getElementById('timelineChart'), {
    type: 'line',
    data: {
        labels: timeLabels,
        datasets: [{
            label: 'Votes per Hour',
            data: timeCounts,
            borderColor: '#1a237e',
            backgroundColor: 'rgba(26,35,126,0.1)',
            fill: true,
            tension: 0.3,
            pointRadius: 5,
        }]
    },
    options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
    }
});
<% } %>
</script>

<%- include('../partials/footer') %>
